# c411 Torznab API Key
# Get yours at: https://c411.ch/myaccount/
C411_API_KEY=your_c411_api_key_here

# AllDebrid API Key
# Get yours at: https://alldebrid.com/account/
ALLDEBRID_API_KEY=your_alldebrid_api_key_here

# Eclipse API Key (optional - for token validation in URLs)
# Generate a random secure token if you want URL protection
ECLIPSE_API_KEY=your_custom_secure_token_here

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Detailed logs (cache hits, headers, chunks, etc.)
# - INFO: Normal logs (requests, streams, results) - RECOMMENDED
# - WARNING: Warnings and errors only
# - ERROR: Errors only
LOG_LEVEL=INFO

