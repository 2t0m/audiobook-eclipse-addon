# c411 Torznab API Key
C411_API_KEY=your_c411_api_key_here

# TR4KER API Key
TR4KER_API_KEY=your_tr4ker_api_key_here

# AllDebrid API Key
ALLDEBRID_API_KEY=your_alldebrid_api_key_here

# Eclipse API Key (optional - for token validation in URLs)
# Generate a random secure token if you want URL protection
ECLIPSE_API_KEY=your_custom_secure_token_here

# Log Levels (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# APP_LOG_LEVEL: application logs (search results, streaming, errors)
#   - DEBUG: Detailed logs (cache hits, headers, chunks, etc.)
#   - INFO: Normal logs (requests, streams, results) - RECOMMENDED
#   - WARNING: Warnings and errors only
#   - ERROR: Errors only
# GUNICORN_LOG_LEVEL: HTTP server logs (access logs, worker management)
#   - WARNING: Only errors/warnings (no HTTP access logs) - RECOMMENDED
#   - INFO: Includes HTTP access logs for each request
APP_LOG_LEVEL=INFO
GUNICORN_LOG_LEVEL=WARNING

